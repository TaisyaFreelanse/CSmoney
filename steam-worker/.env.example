PORT=3001

# VPS: автозапуск после перезагрузки (пример путей под root на Hetzner):
#   sudo cp steam-worker/steam-worker.service /etc/systemd/system/
#   sudo systemctl daemon-reload && sudo systemctl enable --now steam-worker
#   curl -s http://127.0.0.1:3001/health
# Открыть порт 3001 во внешнем фаерволе (Hetzner Cloud / ufw), если Render бьётся по IP:порт.

# JSON array: only userDataDir (paths relative to cwd or absolute)
# STEAM_ACCOUNTS=[{"id":"acc1","userDataDir":"./profiles/acc1"}]

# Optional: default profiles root for `npm run login -- acc1`
# STEAM_PUPPETEER_PROFILES_DIR=./profiles

# Headless: on VPS set 1 (no X11). Visible browser only if DISPLAY works (terminal opened inside VNC desktop).
# STEAM_WORKER_HEADLESS=1
#
# Логин на сервере: из каталога steam-worker выполните `npm run login:vps -- acc1` — скрипт сам выберет headful
# при рабочем DISPLAY (VNC) или headless при SSH без X. Пакеты: apt install -y xvfb x11-utils dbus-x11 (xvfb опционально).

# Set to 1 to log Bright Data geo JSON once per inventory run (before Steam goto). Remove after diagnostics.
# STEAM_WORKER_DEBUG_GEO=1

# Bright Data / HTTP proxy (optional). All Puppeteer traffic uses it when host+port set.
# With proxy, Chromium uses --ignore-certificate-errors (TLS inspection). Do not use on untrusted networks without proxy.
# PROXY_HOST=brd.superproxy.io
# PROXY_PORT=33335
# ISP (dedicated) product: use the zone string from Bright Data (e.g. …-zone-isp_proxy1), not residential, for stable egress.
# Base PROXY_USERNAME without -session-…; code appends -session-{accountId} (e.g. …-session-acc1) per STEAM_ACCOUNTS id.
# Если curl с «как в .env» работает, а с …-session-acc1 — 407: зона Bright Data не принимает такой суффикс.
# Тогда: PROXY_STICKY_SESSION=0 (username как в панели, без доп. -session-) или шаблон с {accountId} в PROXY_USERNAME.
# Or: PROXY_USERNAME=...-session-{accountId}  Placeholder. PROXY_STICKY_SESSION=0 = use username as-is.
# STEAM_WORKER_VERIFY_PROXY_IP=1  — log steam_worker_proxy_ip_verify after authenticate (compare IP across runs).
# If geo.brdtest.com returns 407 for your zone, set e.g. STEAM_WORKER_PROXY_VERIFY_URL=https://api.ipify.org?format=json
# STEAM_WORKER_PROXY_VERIFY_URL=
# PROXY_USERNAME=
# PROXY_PASSWORD=

# Chrome path if not using bundled Chromium
# PUPPETEER_EXECUTABLE_PATH=

# Cooldown after session_invalid (ms), default 20 min
# STEAM_ACCOUNT_INVALID_MS=1200000

# Global concurrent inventory jobs (default 4)
# STEAM_WORKER_MAX_CONCURRENT=4

# Max pending jobs in FIFO (default 50) — overflow → HTTP 429 queue_overflow
# QUEUE_MAX_SIZE=50

# Paginated GET https://steamcommunity.com/inventory/{steamId64}/730/2 before trade UI (same proxy as browser).
# STEAM_WORKER_INVENTORY_API_MAX_PAGES=400 (use 0 or unlimited for cap 2000)
# STEAM_WORKER_INVENTORY_API_TIMEOUT_MS=55000 — per-page HTTPS timeout
# STEAM_WORKER_INVENTORY_API_PAGE_MAX_ATTEMPTS=18 — retries per page (429 + network)
# STEAM_WORKER_INVENTORY_PAGINATION_SCROLL_ROUNDS=48 — scroll partner pane when XHR still has more_items

# Wall-clock cap per Puppeteer task (ms), default 120000, max 180000
# STEAM_WORKER_TASK_TIMEOUT_MS=120000

# Browser / XHR timeouts (inner limits, capped by task timeout). Raise if trade_ui_timeout.
# STEAM_WORKER_MAX_BROWSER_MS=120000
# STEAM_WORKER_PARTNER_XHR_WAIT_MS=30000
# После page.goto на trade URL Chrome иногда даёт chrome-error:// при флаке прокси — повторы goto (по умолчанию 5, макс. 8).
# STEAM_WORKER_TRADE_GOTO_RETRIES=5

# По умолчанию worker ждёт реальный partnerinventory XHR даже при «полном» community API — иначе в merge не попадают слоты только из trade XHR (в т.ч. трейдлок).
# STEAM_WORKER_SKIP_TRADE_XHR_WHEN_API_COMPLETE=1 — старая оптимизация: только prefetch без XHR.

# Log any response URL containing "inventory" (noisy). STEAM_WORKER_DEBUG_XHR=1

# In-memory cache TTL for identical tradeUrl (ms), default 120000
# CACHE_TTL_MS=120000

# Rate limit for GET /inventory (per IP)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=20

# Диагностика прокси и /inventory (без изменения кода сервера):
#   npm run diagnose:inventory-proxy
# Задайте один канонический trade URL для теста (не публикуйте в git):
# STEAM_DIAGNOSTIC_TRADE_URL=https://steamcommunity.com/tradeoffer/new/?partner=...&token=...
# Режим без Bright Data: оставьте пустыми все четыре — PROXY_HOST, PROXY_PORT, PROXY_USERNAME, PROXY_PASSWORD — и перезапустите worker.

# Telegram: алерты по аккаунтам (session_invalid сразу; proxy_error / puppeteer_error после N подряд).
# Не коммитьте реальные токены. Если токен светился в чате — перевыпустите в @BotFather.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_NOTIFY_COOLDOWN_MS=480000   # не чаще одного алерта на accountId (все типы), по умолчанию 8 мин
# TELEGRAM_PROXY_ERROR_STREAK=3
# TELEGRAM_PUPPETEER_ERROR_STREAK=4

# Required for /inventory and /debug/accounts (header x-api-key). Omit only for local dev.
# API_KEY=secret_key

# Behind reverse proxy (for correct client IP in rate limit)
# TRUST_PROXY=1

# Пакетный аудит float из merged `raw` (скрипт `npm run audit:trade-floats` на VPS рядом с worker):
# TRADE_AUDIT_URLS="https://steamcommunity.com/tradeoffer/new/?partner=…&token=…,https://…"
