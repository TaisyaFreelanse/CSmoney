{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && node ./scripts/install-chrome-for-puppeteer.mjs && next build",
    "puppeteer:install": "node ./scripts/install-chrome-for-puppeteer.mjs",
    "start": "node ./scripts/render-start.mjs",
    "render:release": "node ./scripts/render-release.mjs",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:puppeteer-steam": "node ./scripts/test-steam-puppeteer-inventory.mjs"
  },
  "dependencies": {
    "@csfloat/cs2-inspect-serializer": "^1.1.6",
    "@prisma/client": "6.19.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "next": "16.2.1",
    "prisma": "6.19.0",
    "puppeteer": "^24.40.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
