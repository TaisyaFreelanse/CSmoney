# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Puppeteer Chrome for Testing (downloaded at build; do not commit)
/.puppeteer-chrome/

# Persistent Chromium userDataDir sessions (STEAM_PUPPETEER_ACCOUNTS_JSON); do not commit
/profiles/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local owner trade-lock list (large JSON from Steam export)
/data/owner-manual-trade-lock.json
