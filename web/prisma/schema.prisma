// https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TradeStatus {
  pending
  accepted_by_admin
  completed
  cancelled
  rejected
}

enum TradeItemSide {
  owner
  guest
}

model User {
  id          String    @id @default(cuid())
  steamId     String    @unique
  displayName String?
  avatarUrl   String?
  isAdmin     Boolean   @default(false)
  isBanned    Boolean   @default(false)
  lastLoginAt DateTime?
  tradeUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tradesCreated Trade[] @relation("TradeCreator")
}

model Trade {
  id             String      @id @default(cuid())
  creatorSteamId String
  creator        User        @relation("TradeCreator", fields: [creatorSteamId], references: [steamId], onDelete: Restrict)
  status         TradeStatus @default(pending)
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  items TradeItem[]
}

model TradeItem {
  id             String        @id @default(cuid())
  tradeId        String
  trade          Trade         @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  side           TradeItemSide
  /** Display name at submission time (Steam `name` / card title). */
  displayName    String?
  marketHashName String?
  phaseLabel     String?
  assetId        String?
  classId        String?
  instanceId     String?
  wear           String?
  floatValue     Float?
  priceUsd       Decimal?      @db.Decimal(14, 4)
  quantity       Int           @default(1)
  createdAt      DateTime      @default(now())
}

// Price catalog from PriceEmpire — one row per market_hash_name (+ phase where applicable)
model PriceCatalogItem {
  id             String   @id @default(cuid())
  marketHashName String
  phaseKey       String   @default("default")
  providerKey    String   @default("buff163")
  priceUsd       Int // cents to avoid float rounding
  updatedAt      DateTime @updatedAt

  @@unique([marketHashName, phaseKey, providerKey])
  @@index([marketHashName])
}

// Single-row settings for pricing; admin page edits this
model PricingSettings {
  id                    String   @id @default("singleton")
  selectedPriceProvider String   @default("buff163")
  markupGuestPercent    Float    @default(0)
  markupOwnerPercent    Float    @default(0)
  minPriceThresholdUsd  Float    @default(20)
  updatedAt             DateTime @updatedAt
}

// Manual overrides for owner items by assetId: fixed USD or extra % on catalog (after global owner markup)
model OwnerManualPrice {
  id            String   @id @default(cuid())
  assetId       String   @unique
  mode          String   @default("fixed") // "fixed" | "markup_percent"
  priceUsd      Decimal? @db.Decimal(14, 4) // dollars when mode=fixed
  markupPercent Float? // extra % when mode=markup_percent (applied after markupOwnerPercent)
  note          String?
  setAt         DateTime @default(now())
}

// Cached USD→FX rates from ExchangeRate-API (one row); refreshed by cron /api/fx-rates/sync
model FxRatesSnapshot {
  id        String   @id @default("singleton")
  rates     Json // { "USD": 1, "EUR": 0.92, "RUB": 90, ... } — units per 1 USD
  fetchedAt DateTime
}

// Owner: trade-lock-only JSON from admin (e.g. Steam context 16 export). Normalized rows for merged public inventory; no server fetch of context 16.
model OwnerManualTradeLockList {
  id                 String   @id @default("singleton")
  assetIds           String[] @default([])
  classInstanceKeys  String[] @default([]) // "classid_instanceid" from pasted assets[]
  lockDisplayItems   Json? // NormalizedItem[] — merged into /api/inventory/owner with locked: true
  updatedAt          DateTime @updatedAt
}
