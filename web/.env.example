# PostgreSQL (Render / локально)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Опционально: Redis (Render Key Value или локальный Redis) — общий кэш снимков инвентаря между инстансами.
# Internal URL (redis://red-…:6379) только на Render и только в том же регионе, что web-сервис; локально не работает.
# Локально: не задавайте REDIS_URL или используйте external rediss:// из Dashboard (TLS + allowlist IP).
# REDIS_URL="redis://:password@host:6379"

# Логи кэша инвентаря в stdout: GET HIT/MISS, SET, фоновые обновления Steam (1=вкл, 0=выкл). На Render задайте 1 для отладки.
# INVENTORY_CACHE_LOG="1"

# Сессия после входа через Steam (минимум 16 символов; сгенерируйте случайную строку)
SESSION_SECRET="change-me-to-a-long-random-secret"

# Публичный URL приложения (без завершающего слэша) — канонический домен (сессия + Steam return_to).
# Пример: https://chez.trading
# НЕ ставьте сюда localhost на Render — Steam вернёт пользователя на ваш ПК и вход сломается.
# Если не задано, в проде используются заголовки прокси (Render) и/или RENDER_EXTERNAL_URL.
# NEXT_PUBLIC_APP_URL="https://your-app.onrender.com"

# Дополнительные хосты (через запятую, без https): редирект 308 на NEXT_PUBLIC_APP_URL.
# Пример: основной chez.trading, а сюда — cheztrading.com,www.cheztrading.com
# SITE_HOST_ALIASES="cheztrading.com,www.cheztrading.com"

# Steam Web API Key — обязательно для загрузки инвентаря владельца (в т.ч. трейдлок)
# Получить: https://steamcommunity.com/dev/apikey
# STEAM_WEB_API_KEY=""

# Постоянные профили Chromium (рекомендуется на Render + persistent disk). Корень каталогов userDataDir.
# STEAM_PUPPETEER_PROFILES_DIR="/mount/profiles"
# 1 = только профили (userDataDir); игнорировать STEAM_COMMUNITY_COOKIES и поле cookies в STEAM_PUPPETEER_ACCOUNTS_JSON.
# STEAM_PUPPETEER_COOKIES_DISABLED="1"
# Альтернативное имя флага: STEAM_PUPPETEER_PROFILES_ONLY="1"

# Опционально: Cookie заголовок Steam для Puppeteer без профилей (legacy; не смешивать с STEAM_PUPPETEER_COOKIES_DISABLED=1).
# Без cookies/профилей гостевой инвентарь грузится только через публичные community API.
# На сервере нужен Chromium. Отключить браузер: STEAM_INVENTORY_BROWSER=0
# STEAM_COMMUNITY_COOKIES="sessionid=...; steamLoginSecure=..."
# STEAM_INVENTORY_BROWSER="1"

# Steam ID64 владельца сайта — используется для определения чей инвентарь грузить через API Key
# OWNER_STEAM_ID="76561199232400638"

# Не рекомендуется: контекст инвентаря CS2 для магазина (только owner). По умолчанию 2.
# Контекст 16 из выгрузки браузера с сервера Render почти всегда даёт пустой ответ (rwgrsn:-2) или private —
# без браузерной сессии Steam так не отдаёт те же данные. Оставьте пустым (контекст 2).
# Если задать 16, сервер сначала попробует 16, при ошибке сам перейдёт на 2 (лишний запрос к Steam + риск rate limit).
# Ручной трейдлок в админке матчится по assetid и classid+instanceid к инвентарю с контекста 2.
# OWNER_INVENTORY_CONTEXT_ID="16"

# Только пары classid+instanceid из списка (игнорировать asset id). Имеет смысл, если JSON с другого контекста и asset id не совпадают.
# OWNER_MANUAL_TRADE_LOCK_CLASS_INSTANCE_ONLY="true"

# Опционально: JSON со списком assetid в трейдлоке (как ответ Steam { "assets": [...] }).
# Используется только если в БД нет записи (админка → «Трейдлок»). После первого сохранения в админке список берётся из БД.
# Абсолютный путь или относительно process.cwd() (корень web/). Перезагрузка при изменении mtime файла.
# OWNER_MANUAL_TRADE_LOCK_PATH="data/owner-manual-trade-lock.json"

# Опционально: выдать админку по Steam ID64 после успешного входа (через запятую)
# ADMIN_STEAM_IDS="76561198000000000"

# PriceEmpire API Key — для синхронизации цен CS2 скинов
# Получить: https://pricempire.com/
# PRICEMPIRE_API_KEY=""

# Секрет для cron-задач (синхронизация цен по расписанию)
# Сгенерируйте случайную строку
# CRON_SECRET=""

# ExchangeRate-API v6 (Bearer): курсы USD→EUR/RUB/CNY/UAH, ~1 запрос/сутки через cron scripts/sync-fx-rates.mjs
# https://www.exchangerate-api.com/
# EXCHANGE_RATE_API_KEY=""
# Не чаще чем раз в N часов (защита квоты при частом cron). 0 = всегда бить API.
# FX_RATES_MIN_SYNC_INTERVAL_HOURS="20"

# Telegram: один бот, разные каналы (супергруппа/канал: добавьте бота и дайте право писать).
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHAT_ID_TRADES=""      # заявки на обмен (POST /api/trades)
# TELEGRAM_CHAT_ID_SUPPORT=""    # сообщения поддержки (POST /api/chat/send)
# TELEGRAM_CHAT_ID_USERS=""      # новые пользователи (первый Steam login)
