# PostgreSQL (Render / локально)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Сессия после входа через Steam (минимум 16 символов; сгенерируйте случайную строку)
SESSION_SECRET="change-me-to-a-long-random-secret"

# Публичный URL приложения (без завершающего слэша) — канонический домен (сессия + Steam return_to).
# Пример: https://chez.trading
# НЕ ставьте сюда localhost на Render — Steam вернёт пользователя на ваш ПК и вход сломается.
# Если не задано, в проде используются заголовки прокси (Render) и/или RENDER_EXTERNAL_URL.
# NEXT_PUBLIC_APP_URL="https://your-app.onrender.com"

# Дополнительные хосты (через запятую, без https): редирект 308 на NEXT_PUBLIC_APP_URL.
# Пример: основной chez.trading, а сюда — cheztrading.com,www.cheztrading.com
# SITE_HOST_ALIASES="cheztrading.com,www.cheztrading.com"

# Steam Web API Key — обязательно для загрузки инвентаря владельца (в т.ч. трейдлок)
# Получить: https://steamcommunity.com/dev/apikey
# STEAM_WEB_API_KEY=""

# Steam ID64 владельца сайта — используется для определения чей инвентарь грузить через API Key
# OWNER_STEAM_ID="76561199232400638"

# Опционально: выдать админку по Steam ID64 после успешного входа (через запятую)
# ADMIN_STEAM_IDS="76561198000000000"

# PriceEmpire API Key — для синхронизации цен CS2 скинов
# Получить: https://pricempire.com/
# PRICEMPIRE_API_KEY=""

# Секрет для cron-задач (синхронизация цен по расписанию)
# Сгенерируйте случайную строку
# CRON_SECRET=""

# ExchangeRate-API v6 (Bearer): курсы USD→EUR/RUB/CNY/UAH, ~1 запрос/сутки через cron scripts/sync-fx-rates.mjs
# https://www.exchangerate-api.com/
# EXCHANGE_RATE_API_KEY=""
# Не чаще чем раз в N часов (защита квоты при частом cron). 0 = всегда бить API.
# FX_RATES_MIN_SYNC_INTERVAL_HOURS="20"
